# Backend Configuration
# Copy this file to .env and update the values

# Flask server port
# NOTE: macOS users should use 5001 (port 5000 is used by AirPlay Receiver)
FLASK_PORT=5000
FLASK_DEBUG=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Neo4j database connection
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password_here

# Data storage paths
UPLOAD_FOLDER=./uploads
DB_PATH=./research_index_db
COLLECTION_NAME=papers_collection

# Local Ollama model used for RAG synthesis
LLM_MODEL=llama3.2
LLM_NUM_PREDICT=192
OLLAMA_KEEP_ALIVE=10m

# Embedding model (kept local after the initial installation/download)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_LOCAL_FILES_ONLY=true
